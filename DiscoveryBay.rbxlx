	{ "Cheeseburgers", "Cheeseburger" }, { "Hot Dogs", "Hot Dog" }, { "BBQ & Grill", "Hot Dog" },
	{ "Pizza", "Pizza Slice" }, { "Pasta & Italian", "Pizza Slice" }, { "Chips & Snacks", "Chips" },
