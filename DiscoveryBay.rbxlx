	{ "Donuts", "Donut" }, { "Breakfast Cereal", "Cereal" }, { "Dairy", "Milk" },
	{ "Milk & Eggs", "Milk" }, { "Sodas", "Bloxy Cola" }, { "Energy Drinks", "Bloxy Cola" },
	{ "Water & Juice", "Water" }, { "Coffee & Tea", "Coffee" }, { "Ice Cream", "Ice Cream" },
